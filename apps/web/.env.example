# NODERE Intelligence Web — variáveis de ambiente
# Copie para .env.local

# URL da API (apps/api rodando localmente ou no Render)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Chave de autenticação Bearer opcional — deve coincidir com API_KEY no apps/api se endpoints privados exigirem token
NEXT_PUBLIC_API_KEY=

# Supabase Auth público — necessário para login/cadastro/recuperação no frontend
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps público somente se mapa renderizado no navegador. Places permanece no backend.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
