# NODERE Intelligence API — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# Servidor
PORT=4000
NODE_ENV=development
RENDER_EXTERNAL_URL=https://nodere-api.onrender.com

# Autenticação Bearer Token
# Deve coincidir com NEXT_PUBLIC_API_KEY no apps/web/.env.local
API_KEY=seu-token-secreto-aqui

# Google APIs — use GOOGLE_API_KEY como chave universal (fallback para todas)
GOOGLE_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_PAGESPEED_API_KEY=

# Google Business Profile (OAuth)
GOOGLE_BUSINESS_PROFILE_CLIENT_ID=
GOOGLE_BUSINESS_PROFILE_CLIENT_SECRET=
GOOGLE_BUSINESS_PROFILE_REFRESH_TOKEN=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Enriquecimento CNPJ/decisores
ECONODATA_API_KEY=
ECONODATA_API_URL=
APOLLO_API_KEY=
APOLLO_API_URL=https://api.apollo.io/api/v1

# WhatsApp Cloud API
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_SECRET=nodere-webhook-secret
WHATSAPP_DEFAULT_COUNTRY_CODE=55

# CORS — origem do frontend
WEB_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Banco de dados (Supabase connection string)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SMTP (sequências de e-mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nodere.com.br

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
STRIPE_STARTER_URL=
STRIPE_PRO_URL=
STRIPE_AGENCY_URL=
STRIPE_SUCCESS_URL=http://localhost:3000/billing?success=1
STRIPE_CANCEL_URL=http://localhost:3000/billing?cancel=1

# Push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@nodere.com.br

# Social media OAuth
META_APP_ID=
META_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
GOOGLE_BUSINESS_CLIENT_ID=
GOOGLE_BUSINESS_CLIENT_SECRET=
SOCIAL_TOKEN_ENCRYPTION_KEY=

# Marketplace integrations
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
RDSTATION_CLIENT_ID=
RDSTATION_CLIENT_SECRET=

# Social/Ads OAuth adicionais
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
X_API_KEY=
X_API_SECRET=
GOOGLE_BUSINESS_CLIENT_ID=
GOOGLE_BUSINESS_CLIENT_SECRET=

# Google Calendar / Outlook
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# CNPJ enrichment
RECEITAWS_ENABLED=true

# Dados mock (true em dev, false em produção)
USE_MOCK_DATA=true
